LLM_PROVIDER=google
LLM_MODEL=gemini-3-flash-preview
LLM_TEMPERATURE=0.2
LLM_HTTP_TRUST_ENV=false

GOOGLE_API_KEY=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ROUTING_LLM_PROVIDER=
ROUTING_LLM_MODEL=
ROUTING_LLM_TEMPERATURE=
ROUTING_LLM_HTTP_TRUST_ENV=
ROUTING_GOOGLE_API_KEY=
ROUTING_MINIMAX_API_KEY=
ROUTING_MINIMAX_BASE_URL=
ROUTING_OPENAI_API_KEY=
ROUTING_OPENAI_BASE_URL=

GOOGLE_APPLICATION_CREDENTIALS=credentials.json
JADE_PROJECT_SHEET_ID=
PROJECT_SHEET_RANGE=Tasks!A1:Z
ASSISTANT_REQUEST_PARSER_CONFIDENCE_THRESHOLD=0.60
PENDING_ACTION_PARSER_CONFIDENCE_THRESHOLD=0.75
KNOWLEDGE_BASE_DIR=knowledge
KNOWLEDGE_GOOGLE_SHEETS_CATALOG_PATH=knowledge/AI/Rules/google_sheets_catalog.json
CONVERSION_WORK_DIR=runtime/conversion
LANGGRAPH_CHECKPOINT_DB_PATH=
JADE_PROJECT_SKILLS_DIR=.jade/skills

# --- Memory scaffolding (path surface + future long-term/retrieval toggles) ---
MEMORY_WORK_DIR=runtime/memory
LONG_TERM_MEMORY_ENABLED=false
MEMORY_RETRIEVAL_ENABLED=false
MEMORY_RETRIEVAL_DEFAULT_LIMIT=8
MEMORY_CONSOLIDATION_ENABLED=false
MEMORY_CONSOLIDATION_MIN_ENTRIES=8
MEMORY_CONSOLIDATION_DEBOUNCE_SECONDS=5
SESSION_MEMORY_ENABLED=true
SESSION_MEMORY_INITIALIZE_THRESHOLD_TOKENS=2048
SESSION_MEMORY_UPDATE_GROWTH_THRESHOLD_TOKENS=768
CONTEXT_WINDOW_AUTO_COMPACT_ENABLED=true
CONTEXT_WINDOW_AUTO_COMPACT_PRESERVED_TAIL_COUNT=1
CONTEXT_WINDOW_AUTO_COMPACT_FAILURE_LIMIT=3

SLACK_ENABLED=true
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_THINKING_REACTION=eyes

WEB_ENABLED=false
WEB_HOST=127.0.0.1
WEB_PORT=8000
# Comma-separated list of allowed hostnames (e.g. myserver.example.com). Leave blank to allow all.
WEB_ALLOWED_HOSTS=

# --- Web authentication (enable before exposing on a public URL) ---
WEB_AUTH_ENABLED=false
# Single-user shorthand:
WEB_AUTH_USERNAME=
WEB_AUTH_PASSWORD=
# Multi-user (comma-separated "user:pass,user2:pass2"):
WEB_AUTH_CREDENTIALS=
# Secret for session signing — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEB_AUTH_SESSION_SECRET=
# Set to true when serving over HTTPS:
WEB_AUTH_COOKIE_SECURE=true
WEB_AUTH_SESSION_MAX_AGE_SECONDS=43200
